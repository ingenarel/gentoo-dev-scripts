die(){ # {{{
    for (( i = "${#1}"; i > 0; i-- )); do
        printf "="
    done
    printf "\n%s\n" "$1"

    local secondBreak
    secondBreak="$( for (( i = "${#0}"; i > 0; i-- )); do
        printf "="
    done)"

    echo "$secondBreak"
    echo "$0"
    echo "$secondBreak"
    exit 1
} # }}}

printVariable(){ # {{{
    local varName="$1"
    local varData="$2"
    local shouldAppendVar="$3"
    printf '# apply-crates-fixes start\n'
    # shellcheck disable=SC2015
    [[ "$shouldAppendVar" == 1 ]] && {
        printf "%s+" "$varName"
        } || {
        printf "%s" "$varName"
    }
    printf '="%b\n"\n# apply-crates-fixes end\n' "$varData"
} # }}}

printFunction(){ # {{{
    local funcData="$1"
    local funcName="$2"
    local shouldInsertFuncData="$3"
    local defaultFuncDataIfNotNew="$4"

    [[ "$shouldInsertFuncData" == 1 ]] && printf '\t'
    printf '# apply-crates-fixes start\n'
    # shellcheck disable=SC2015
    [[ "$shouldInsertFuncData" == 1 ]] && {
        printf '%b' "$funcData"
        } || {
        printf "%s(){\n%b%b}\n"\
            "$funcName"\
            "$funcData"\
            "$defaultFuncDataIfNotNew"
    }
    [[ "$shouldInsertFuncData" == 1 ]] && printf '\t'
    printf '# apply-crates-fixes end\n'
} # }}}

sanitizeEbuild(){ # {{{
    local filepath="$1"
    local ignoreLines=false
    while IFS='' read -r line; do
        case "$line" in
            *"# apply-crates-fixes start")
                ignoreLines=true
                ;;
            *"# apply-crates-fixes end")
                ignoreLines=false
                ;;
            *)
                $ignoreLines || {
                    printf '%s\n' "$line"
                }
                ;;
        esac
    done < "$filepath"
} # }}}

addVariableToEbuild(){ # {{{
    local filepath="$1"
    local varToCheck="$2"
    local varToAdd="$3"
    local varData="$4"
    local varLoadOrder="$5"
    local shouldAppendVar="$6"

    local mulilineVar=false
    local variablePrinted=false
    local ebuildData=""
    while IFS='' read -r line; do
        # it will currently only try to append after the variables that were assigned using `VAR=`, and not `VAR+=`,
        # however it wont technically break an ebuild, so i'm not currently implementing a fix now, which would be kinda
        # complex to implement
        case "$line" in
            "$varToCheck=\""*\")
                ebuildData+="$line\n"
                ebuildData+="$(
                    printVariable\
                        "$varToAdd"\
                        "$varData"\
                        "$shouldAppendVar"
                )\n"
                variablePrinted=true
                ;;
            "$varToCheck=\"")
                ebuildData+="$line\n"
                mulilineVar=true
                ;;
            '"')
                ebuildData+="$line\n"
                $mulilineVar && {
                    ebuildData+="$(
                        printVariable\
                            "$varToAdd"\
                            "$varData"\
                            "$shouldAppendVar"
                    )\n"
                    variablePrinted=true
                    mulilineVar=false
                }
                ;;
            *)
                ebuildData+="$line\n"
        esac
    done < "$filepath"
    if $variablePrinted; then
        printf "%b" "$ebuildData"
    else
        if [[ -n "$varLoadOrder" ]]; then
            firstVar="$( grep -oE '^\S+' <<< "$varLoadOrder" )"
            loadOrder="$( sed -E "s|^$firstVar ||" <<< "$varLoadOrder" )"
            # echo "'$firstVar'"
            # echo "'$loadOrder'"
            addVariableToEbuild\
                "$filepath"\
                "$firstVar"\
                "$varToAdd"\
                "$varData"\
                "$loadOrder"
        else
            echo "loadOrder is empty" 1>&2
        fi
    fi
} # }}}

addLlvmCompatToEbuild(){ # {{{
    local filepath="$1"
    local versions="$2"
    local shouldUpdate="$3"
    while IFS='' read -r line; do
        case "$line" in
            'CRATES='*)
                ! $shouldUpdate &&
                printf '# apply-crates-fixes start\nLLVM_COMPAT=( %b )\n# apply-crates-fixes end\n' "$versions"
                printf '%s\n' "$line"
                ;;
            'LLVM_COMPAT=('*)
                $shouldUpdate &&
                printf 'LLVM_COMPAT=( %b )\n# LLVM_COMPAT needed to be updated by apply-crates-fixes\n' "$versions"
                ;;
            *)
                printf '%s\n' "$line"
                ;;
        esac
    done < "$filepath"
} # }}}

addInheritToEbuild(){ # {{{
    local filepath="$1"
    local eclasses="$2"

    local inheritFound=false
    while IFS='' read -r line; do
        case "$line" in
            'inherit '*)
                printf '%s\n' "$line"
                ! $inheritFound && {
                    printf '# apply-crates-fixes start\ninherit%b\n# apply-crates-fixes end\n' "$eclasses"
                }
                inheritFound=true
                ;;
            *)
                printf '%s\n' "$line"
                ;;
        esac
    done < "$filepath"
} # }}}

insertNewFunction(){ # {{{
    local filepath="$1"
    local funcName="$2"
    local funcData="$3"
    local prevFuncLoadOrder="$4"
    local afterFuncLoadOrder="$5"
    local defaultFuncDataIfNotNew="$6"

    local needToAppend=false
    local functionToCheck=''
    for func in $prevFuncLoadOrder; do
        if grep -qE "^$func\\(\\)\\s*{" "$filepath"; then
            needToAppend=true
            functionToCheck="$func"
            break
        fi
    done
    if $needToAppend; then
        # echo "needToAppend"
        # echo "$functionToCheck"
        local functionFound=false
        while IFS='' read -r line; do
            case "$line" in
                "$functionToCheck(){"|"$functionToCheck() {")
                    printf '%s\n' "$line"
                    functionFound=true
                    ;;
                "}")
                    printf '%s\n' "$line"
                    $functionFound && {
                        functionFound=false
                        # empty lines kind of get jumbled up
                        # TODO: need to fix it
                        printf '%s\n' "$(
                            printFunction\
                                "$funcData"\
                                "$funcName"\
                                0\
                                "$defaultFuncDataIfNotNew"
                        )"
                    }
                    ;;
                *)
                    printf '%s\n' "$line"
                    ;;
            esac
        done < "$filepath"
    else
        local needToPrepend=false
        for func in $afterFuncLoadOrder; do
            if grep -qE "^$func\\(\\)\\s*{" "$filepath"; then
                needToPrepend=true
                functionToCheck="$func"
                break
            fi
        done
        if $needToPrepend; then
            # echo "needToPrepend"
            # echo "$functionToCheck"
            while IFS='' read -r line; do
                case "$line" in
                    "$functionToCheck(){"|"$functionToCheck() {")
                        printf '%s\n%s\n' "$(
                            printFunction\
                                "$funcData"\
                                "$funcName"\
                                0\
                                "$defaultFuncDataIfNotNew"
                        )" "$line"
                        ;;
                    *)
                        printf '%s\n' "$line"
                        ;;
                esac
            done < "$filepath"
        else
            cat "$filepath"
            printf '%s\n' "$(
                printFunction\
                    "$funcData"\
                    "$funcName"\
                    0\
                    "$defaultFuncDataIfNotNew"
            )"
        fi
    fi
} # }}}

prependDataToFunction(){ # {{{
    local filepath="$1"
    local funcName="$2"
    local funcData="$3"
    while IFS='' read -r line; do
        case "$line" in
            "$funcName(){"|"$funcName() {")
                printf '%s\n' "$line"
                printf '%s\n' "$( printFunction "$funcData" "$funcName" 1)"
                ;;
            *)
                printf '%s\n' "$line"
                ;;
        esac
    done < "$filepath"
} # }}}

createOrInsertFunction(){ # {{{
    local filepath="$1"
    local funcName="$2"
    local funcData="$3"
    local prevFuncLoadOrder="$4"
    local afterFuncLoadOrder="$5"
    local defaultFuncDataIfNotNew="$6"
    if grep -qE "^$funcName\\(\\)\\s*\\{" "$filepath"; then
        prependDataToFunction "$filepath" "$funcName" "$funcData"
    else
        insertNewFunction\
            "$filepath"\
            "$funcName"\
            "$funcData"\
            "$prevFuncLoadOrder"\
            "$afterFuncLoadOrder"\
            "$defaultFuncDataIfNotNew"
    fi
} # }}}

showHelp(){ # {{{
    printf "
apply-crates-fixes EBUILD_FILE_PATH

EBUILD_FILE_PATH should be the ebuild file path; passed in as an argument

depends on:
- /bin/sh executable that's a posix sh compliant shell or symlinked to one
- sort command that has --version-sort (GNU sort will do)
- sed and grep

features:
- auto fixes the ebuild
- doesn't fix the ebuild if it's not needed
- autoremoves the fixes if it detects it's not needed anymore
- implements a proper load order for inserting variables and functions and tries to maintain the order from the
  devmanual

created live on stream: https://www.youtube.com/@ingenarel

\n"
} # }}}

{ [[ -n "$1" ]] && [[ -e "$1" ]]; } || { showHelp && exit; }

mainEbuildFilePath="$(realpath "$1")"

deps=''
# bdeps=''
compileFixes=''
inheritFixes=''
llvmCompatVersions=''
changeLlvmCompat=false

sanitizeEbuild "$mainEbuildFilePath" > "$mainEbuildFilePath.sanitized"

grep -qE '^\s*zstd-sys@' "$mainEbuildFilePath.sanitized" && { # {{{
    zstd_crate_version="$(sed -nE 's|^\s*zstd@?([0-9.]+)$|\1|p' "$mainEbuildFilePath.sanitized" )"
    [[ -z "$zstd_crate_version" ]] &&
    die "zstd-sys crate was detected however no zstd crate was detected"
    printf '%s\n%s' '0.12.2' "$zstd_crate_version" | sort --version-sort --check=quiet && {
        zstd_version_from_zstd_sys_crate="$(
			sed -nE 's|^\s*zstd-sys@\S+\+zstd\.(\S+)|\1|p' "$mainEbuildFilePath.sanitized"
		)"
        [[ -z "$zstd_version_from_zstd_sys_crate" ]] &&
        die "couldn't get the minimum version for app-arch/zstd by trying to parse the zstd-sys crate"
        deps+="\n\t>=app-arch/zstd-$zstd_version_from_zstd_sys_crate"
        compileFixes+="\texport ZSTD_SYS_USE_PKG_CONFIG=1 # fix for zstd-sys crate\n"
    }
} # }}}

grep -qE '^\s*libfuzzer-sys@' "$mainEbuildFilePath.sanitized" && { # {{{
    libfuzzer_crate_version="$(sed -nE 's|^\s*libfuzzer-sys@?([0-9.]+)$|\1|p' "$mainEbuildFilePath.sanitized" )"
    [[ -z "$libfuzzer_crate_version" ]] &&
    die "libfuzzer-sys crate was detected however the crate version couldn't be parsed"
    case "$libfuzzer_crate_version" in
        '0.4.12'|'0.4.11')
            grep -qE '^inherit\s+.*llvm-r2' "$mainEbuildFilePath.sanitized" || inheritFixes+=' llvm-r2'
            LLVM_COMPAT_VERSIONS="$(
                source "$mainEbuildFilePath.sanitized" >/dev/null 2>&1
                echo "${LLVM_COMPAT[@]}"
            )"
            [[ -n "$LLVM_COMPAT_VERSIONS" ]] && {
                [[ "$LLVM_COMPAT_VERSIONS" == 22* ]] || {
                    [[ "$LLVM_COMPAT_VERSIONS" == *22 ]] &&
                    llvmCompatVersions='22' ||
                    llvmCompatVersions="22 ${LLVM_COMPAT_VERSIONS##*22 }"
                    changeLlvmCompat=true
                }
            } ||  llvmCompatVersions='22'
            deps+="\n\t\$(llvm_gen_dep 'llvm-core/clang:\${LLVM_SLOT}')"
            compileFixes+='\tCUSTOM_LIBFUZZER_PATH="$(clang --print-file-name "libclang_rt.fuzzer-${ARCH%%-*}.a" )"\n'
            ;;
        *)
            {
                echo "the current version of libfuzzer-sys crate: '$libfuzzer_crate_version' isn't supported"
                echo "please open an ISSUE or PR if you need to unbundle the deps for that one"
            } 1>&2
            ;;
    esac
} # }}}

