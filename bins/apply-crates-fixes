if [[ -n $llvmCompatVersions ]]; then
    addLlvmCompatToEbuild "$mainEbuildFilePath.sanitized"\
        "$llvmCompatVersions" "$changeLlvmCompat" > "$mainEbuildFilePath.llvmcompatfixes"
else
    cp "$mainEbuildFilePath.sanitized" "$mainEbuildFilePath.llvmcompatfixes"
fi

if [[ -n "$inheritFixes" ]]; then
    addInheritToEbuild "$mainEbuildFilePath.llvmcompatfixes" "$inheritFixes"\
        > "$mainEbuildFilePath.inheritfixes"
else
    cp "$mainEbuildFilePath.llvmcompatfixes" "$mainEbuildFilePath.inheritfixes"
fi

if [[ -n "$deps" ]]; then
    addVariableToEbuild "$mainEbuildFilePath.inheritfixes" DEPEND DEPEND "$deps"\
        'RESTRICT PROPERTIES REQUIRED_USE IUSE KEYWORDS SLOT LICENSE SRC_URI' 1\
        > "$mainEbuildFilePath.depsfixes"
else
    cp "$mainEbuildFilePath.inheritfixes" "$mainEbuildFilePath.depsfixes"
fi

if [[ -n "$compileFixes" ]]; then
    createOrInsertFunction\
        "$mainEbuildFilePath.depsfixes"\
        "src_compile"\
        "$compileFixes"\
        'src_configure src_prepare src_unpack pkg_setup pkg_nofetch pkg_pretend'\
        'src_test src_install pkg_preinst pkg_postinst pkg_prerm pkg_postrm pkg_config pkg_info'\
        '\tcargo_src_compile\n'\
        > "$mainEbuildFilePath.compilefixes"
else
    cp "$mainEbuildFilePath.depsfixes" "$mainEbuildFilePath.compilefixes"
fi

rm "$mainEbuildFilePath.sanitized"
rm "$mainEbuildFilePath.llvmcompatfixes"
rm "$mainEbuildFilePath.inheritfixes"
rm "$mainEbuildFilePath.depsfixes"
cp "$mainEbuildFilePath.compilefixes" "$mainEbuildFilePath"
rm "$mainEbuildFilePath.compilefixes"
